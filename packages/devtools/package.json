{
  "name": "radar-devtools",
  "version": "0.4.6",
  "description": "Radar client SDK for React Native apps",
  "license": "MIT",
  "author": "Lucas Figueiredo <lucasfigueiredo285@gmail.com> (https://www.figueiredolucas.com.br)",
  "homepage": "https://github.com/lucas-figueiredo-m/radar#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucas-figueiredo-m/radar.git",
    "directory": "packages/devtools"
  },
  "bugs": {
    "url": "https://github.com/lucas-figueiredo-m/radar/issues"
  },
  "keywords": [
    "react-native",
    "devtools",
    "debugging",
    "profiler",
    "console",
    "network",
    "mcp",
    "ai"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./babel-plugin": "./babel-plugin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "babel-plugin.js",
    "android/src",
    "android/build.gradle",
    "ios",
    "src/NativeRadarPerformance.ts",
    "react-native.config.js",
    "RadarDevtools.podspec",
    "README.md"
  ],
  "private": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@radar/types": "workspace:*",
    "@types/babel__core": "^7.20.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.19.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "2.8.8",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.72.0",
    "@react-native-async-storage/async-storage": ">=1.0.0",
    "react-native-mmkv": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@react-native-async-storage/async-storage": {
      "optional": true
    },
    "react-native-mmkv": {
      "optional": true
    }
  },
  "codegenConfig": {
    "name": "RadarDevtoolsSpec",
    "type": "modules",
    "jsSrcsDir": "src"
  }
}
